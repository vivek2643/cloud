# Copy to terraform.tfvars and adjust. Most defaults are fine for a demo.

region        = "us-west-2"
instance_type = "g5.12xlarge" # 4x A10G -> 4 videos ingest in parallel
use_spot      = false         # true = ~60-70% cheaper, can be interrupted

# Worker fleet sizing (optional; gpu_workers empty = 1 per GPU).
# gpu_workers        = "4"
# cpu_workers        = 2
# worker_concurrency = 1

# Secrets: by default Terraform bakes in the repo-root .env. Override if needed:
# env_file_path = "/absolute/path/to/.env"

# Only if the GHCR image package is PRIVATE:
# ghcr_user = "vivek2643"
# ghcr_pat  = "ghp_xxx"   # read:packages scope

# Only if you want SSH (otherwise use SSM Session Manager, no inbound port):
# ssh_key_name     = "my-keypair"
# allowed_ssh_cidr = "1.2.3.4/32"
