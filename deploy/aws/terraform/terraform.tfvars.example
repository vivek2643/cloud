# Copy to terraform.tfvars and adjust. Defaults match the approved setup:
# us-east-1, Spot-only (On-Demand G quota = 0), 2x g5.2xlarge = 2 GPUs.

region        = "us-east-1"
aws_profile   = "edso"
instance_type = "g5.2xlarge" # 1x A10G per box
worker_count  = 2            # 2 boxes = 16 vCPU = Spot G quota ceiling
use_spot      = true         # On-Demand G is quota-blocked here

# Worker fleet sizing (optional; gpu_workers empty = 1 per GPU).
# gpu_workers        = ""    # auto: 1 per detected GPU
# cpu_workers        = 1
# worker_concurrency = 1

# Secrets: Terraform bakes in the repo-root .env by default. Override if needed:
# env_file_path = "/absolute/path/to/.env"

# GHCR package is public, so no login needed. If you make it private later:
# ghcr_user = "vivek2643"
# ghcr_pat  = "ghp_xxx"   # read:packages scope

# Optional SSH (otherwise use SSM Session Manager, no inbound port):
# ssh_key_name     = "my-keypair"
# allowed_ssh_cidr = "1.2.3.4/32"
