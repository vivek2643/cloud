# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=aerodrive

# Pipeline
# LLM backbone for L3 editorial reasoning. "anthropic" (default) or "gemini".
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-key
# Gemini (only needed when LLM_PROVIDER=gemini; pip install google-genai)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# --- L2: VLM perception (Gemini) ---
# One deep Gemini pass per short clip after L1 (the "footage log"). Reuses
# GEMINI_API_KEY above. Cost scales ~linearly with length, so it's gated by
# duration; the limit is a constant you can move.
ENABLE_L2_PERCEPTION=true
# Temporarily 60 min; we'll split long videos later rather than gating them.
L2_MAX_DURATION_SECONDS=3600
L2_GEMINI_MODEL=gemini-2.5-flash
L2_VIDEO_FPS=1.0
# Per-frame token budget: low | default | high
L2_MEDIA_RESOLUTION=default
L2_MAX_OUTPUT_TOKENS=32768
L2_FILE_ACTIVE_TIMEOUT_SECONDS=300

# Layer C: keyframe images attached to the (legacy) multimodal editor call.
EDITOR_VISION_MAX_IMAGES=16

# Agentic perception (director is a blind editor that pulls keyframes on demand).
EDITOR_PERCEPTION_MAX_ROUNDS=12
EDITOR_PERCEPTION_MAX_IMAGES=300
VIEW_FRAMES_PER_SHOT_MAX=8
EDITOR_PERCEPTION_KEEP_IMAGE_TURNS=3
LLM_PROMPT_CACHING=true

# Frontend (prefixed with NEXT_PUBLIC_ for browser access)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000
