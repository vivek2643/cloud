# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=aerodrive

# Postgres (scale_architecture.plan.md Pillar 1)
# Session pooler / direct connection -- Procrastinate (LISTEN/NOTIFY) and the
# migration runner's advisory lock need this route; never point it at a
# transaction-mode pooler.
DATABASE_URL=postgresql://postgres.your-project:your-password@your-pooler-host:5432/postgres
# Transaction pooler (Supavisor, port 6543) -- business-query connections
# (app/services/db.py's pool) borrow from here. Falls back to DATABASE_URL
# when unset.
DATABASE_POOL_URL=postgresql://postgres.your-project:your-password@your-pooler-host:6543/postgres
# Per-worker-process cap on the business-query pool above.
DB_POOL_MAX_SIZE=8

# Process-global bounded pools (scale_architecture.plan.md Pillar 3) -- every
# ffmpeg/ffprobe subprocess and every R2 GET/PUT acquires one of these before
# running, bounding how many are in flight across ALL runs/files on this
# worker process, not just within one.
FFMPEG_CONCURRENCY=4
R2_CONCURRENCY=16

# Pipeline
# LLM backbone for L3 editorial reasoning. "anthropic" (default) or "gemini".
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-key
# Gemini (only needed when LLM_PROVIDER=gemini; pip install google-genai)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# --- L3: edit orchestrator (Claude Opus agentic loop) ---
# Uses ANTHROPIC_API_KEY above. Prompt caching keeps the many-iteration loop
# affordable; guardrails bound each run.
L3_MODEL=claude-opus-4-8
L3_MAX_ITERATIONS=40
L3_MAX_OUTPUT_TOKENS=16384
L3_THINKING_BUDGET_TOKENS=8192
LLM_PROMPT_CACHING=true

# Frontend (prefixed with NEXT_PUBLIC_ for browser access)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000
