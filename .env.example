# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=aerodrive

# Pipeline
# LLM backbone for L3 editorial reasoning. "anthropic" (default) or "gemini".
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-key
# Gemini (only needed when LLM_PROVIDER=gemini; pip install google-genai)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# --- L3: edit orchestrator (Claude Opus agentic loop) ---
# Uses ANTHROPIC_API_KEY above. Prompt caching keeps the many-iteration loop
# affordable; guardrails bound each run.
L3_MODEL=claude-opus-4-8
L3_MAX_ITERATIONS=40
L3_MAX_OUTPUT_TOKENS=16384
L3_THINKING_BUDGET_TOKENS=8192
LLM_PROMPT_CACHING=true

# Frontend (prefixed with NEXT_PUBLIC_ for browser access)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000
